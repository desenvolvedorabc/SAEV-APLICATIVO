# ==========================================
# SAEV Frontend - Configurações de Ambiente
# ==========================================
# Este arquivo contém todas as variáveis de ambiente necessárias para o frontend
# Para desenvolvimento local, copie este arquivo para .env.development e ajuste conforme necessário

# ------------------------------------------
# Ambiente
# ------------------------------------------
# Define o ambiente de execução (development, production, test)
NODE_ENV=development

# ------------------------------------------
# URLs da API
# ------------------------------------------
# URL base da API backend
# IMPORTANTE: Incluir o prefixo /v1 que é configurado globalmente no backend
NEXT_PUBLIC_API_URL=http://localhost:3003

# URL para importação de dados (pode ser diferente da API principal em alguns cenários)
NEXT_PUBLIC_API_URL_IMPORT=http://localhost:3003

# ------------------------------------------
# URLs da Aplicação
# ------------------------------------------
# URL do domínio do frontend (usado para redirecionamentos e links)
NEXT_PUBLIC_DOMAIN_URL=http://localhost:3000

# ------------------------------------------
# Configurações de Paginação
# ------------------------------------------
# Número de itens por página nas listagens
NEXT_PUBLIC_LIMIT_PAGE=10
